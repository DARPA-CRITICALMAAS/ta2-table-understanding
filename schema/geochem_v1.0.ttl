#################################################################
#    Classes
#################################################################

###  https://geochemistry.isi.edu/ontology/Analysis
:Analysis rdf:type owl:Class ;
          rdfs:label "Analysis"@en .


###  https://geochemistry.isi.edu/ontology/Element
:Element rdf:type owl:Class ;
         rdfs:label "Element"@en .


###  https://geochemistry.isi.edu/ontology/Isotope
:Isotope rdf:type owl:Class ;
         rdfs:label "Isotope"@en .


###  https://geochemistry.isi.edu/ontology/Sample
:Sample rdf:type owl:Class ;
        rdfs:label "Sample"@en .


###  https://minmod.isi.edu/ontology/BoundingBox
mo:BoundingBox rdf:type owl:Class ;
             rdfs:subClassOf [ rdf:type owl:Restriction ;
                               owl:onProperty mo:x_max ;
                               owl:cardinality "1"^^xsd:nonNegativeInteger
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty mo:x_min ;
                               owl:cardinality "1"^^xsd:nonNegativeInteger
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty mo:y_max ;
                               owl:cardinality "1"^^xsd:nonNegativeInteger
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty mo:y_min ;
                               owl:cardinality "1"^^xsd:nonNegativeInteger
                             ] ;
             rdfs:label "Bounding Box"@en .


###  https://minmod.isi.edu/ontology/Commodity
mo:Commodity rdf:type owl:Class ;
           rdfs:subClassOf mo:ThingHasLabel ;
           rdfs:label "Commodity"@en .


###  https://minmod.isi.edu/ontology/CommodityCandidate
mo:CommodityCandidate rdf:type owl:Class ;
                    rdfs:subClassOf mo:MatchInfo ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty mo:normalized_uri ;
                                      owl:allValuesFrom mo:Commodity
                                    ] ;
                    rdfs:label "Commodity Candidate"@en .


###  https://minmod.isi.edu/ontology/CoordinateReferenceSystem
mo:CoordinateReferenceSystem rdf:type owl:Class ;
                           rdfs:subClassOf mo:ThingHasLabel ;
                           rdfs:label "Coordinate Reference System"@en .


###  https://minmod.isi.edu/ontology/CoordinateReferenceSystemCandidate
mo:CoordinateReferenceSystemCandidate rdf:type owl:Class ;
                                    rdfs:subClassOf mo:MatchInfo ,
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty mo:normalized_uri ;
                                                      owl:allValuesFrom mo:CoordinateReferenceSystem
                                                    ] ;
                                    rdfs:label "Coordinate Reference System Candidate"@en .


###  https://minmod.isi.edu/ontology/Country
mo:Country rdf:type owl:Class ;
         rdfs:subClassOf mo:ThingHasLabel ;
         rdfs:label "Country"@en .


###  https://minmod.isi.edu/ontology/CountryCandidate
mo:CountryCandidate rdf:type owl:Class ;
                  rdfs:subClassOf mo:MatchInfo ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty mo:normalized_uri ;
                                    owl:allValuesFrom mo:Country
                                  ] ;
                  rdfs:label "Country Candidate"@en .


###  https://minmod.isi.edu/ontology/DepositType
mo:DepositType rdf:type owl:Class ;
             rdfs:subClassOf mo:ThingHasLabel ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty mo:environment ;
                               owl:cardinality "1"^^xsd:nonNegativeInteger
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty mo:group ;
                               owl:cardinality "1"^^xsd:nonNegativeInteger
                             ] ;
             rdfs:label "Deposit Type"@en .


###  https://minmod.isi.edu/ontology/DepositTypeCandidate
mo:DepositTypeCandidate rdf:type owl:Class ;
                      rdfs:subClassOf mo:MatchInfo ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty mo:normalized_uri ;
                                        owl:allValuesFrom mo:DepositType
                                      ] ;
                      rdfs:label "Deposit Type Candidate"@en .


###  https://minmod.isi.edu/ontology/Document
mo:Document rdf:type owl:Class ;
          rdfs:subClassOf [ rdf:type owl:Restriction ;
                            owl:onProperty mo:description ;
                            owl:maxCardinality "1"^^xsd:nonNegativeInteger
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty mo:doi ;
                            owl:maxCardinality "1"^^xsd:nonNegativeInteger
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty mo:issue ;
                            owl:maxCardinality "1"^^xsd:nonNegativeInteger
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty mo:journal ;
                            owl:maxCardinality "1"^^xsd:nonNegativeInteger
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty mo:month ;
                            owl:maxCardinality "1"^^xsd:nonNegativeInteger
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty mo:title ;
                            owl:maxCardinality "1"^^xsd:nonNegativeInteger
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty mo:uri ;
                            owl:maxCardinality "1"^^xsd:nonNegativeInteger
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty mo:volume ;
                            owl:maxCardinality "1"^^xsd:nonNegativeInteger
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty mo:year ;
                            owl:maxCardinality "1"^^xsd:nonNegativeInteger
                          ] ;
          rdfs:label "Document"@en .


###  https://minmod.isi.edu/ontology/EvidenceLayer
mo:EvidenceLayer rdf:type owl:Class ;
               rdfs:subClassOf mo:ThingHasLabel ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty mo:relevance_score ;
                                 owl:cardinality "1"^^xsd:nonNegativeInteger
                               ] ;
               rdfs:label "Evidence Layer"@en .


###  https://minmod.isi.edu/ontology/GeologyInfo
mo:GeologyInfo rdf:type owl:Class ;
             rdfs:subClassOf [ rdf:type owl:Restriction ;
                               owl:onProperty mo:age ;
                               owl:maxCardinality "1"^^xsd:nonNegativeInteger
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty mo:comments ;
                               owl:maxCardinality "1"^^xsd:nonNegativeInteger
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty mo:description ;
                               owl:maxCardinality "1"^^xsd:nonNegativeInteger
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty mo:unit_name ;
                               owl:maxCardinality "1"^^xsd:nonNegativeInteger
                             ] ;
             rdfs:label "Geology Info"@en .


###  https://minmod.isi.edu/ontology/LocationInfo
mo:LocationInfo rdf:type owl:Class ;
              rdfs:subClassOf [ rdf:type owl:Restriction ;
                                owl:onProperty mo:crs ;
                                owl:maxCardinality "1"^^xsd:nonNegativeInteger
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty mo:location ;
                                owl:maxCardinality "1"^^xsd:nonNegativeInteger
                              ] ;
              rdfs:label "Location Info"@en .


###  https://minmod.isi.edu/ontology/MappableCriteria
mo:MappableCriteria rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty mo:criteria ;
                                    owl:cardinality "1"^^xsd:nonNegativeInteger
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty mo:theoretical ;
                                    owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                  ] ;
                  rdfs:label "Mappable Criteria"@en .


###  https://minmod.isi.edu/ontology/MatchInfo
mo:MatchInfo rdf:type owl:Class ;
           rdfs:subClassOf [ rdf:type owl:Restriction ;
                             owl:onProperty mo:source ;
                             owl:allValuesFrom xsd:string
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty mo:source ;
                             owl:cardinality "1"^^xsd:nonNegativeInteger
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty mo:normalized_uri ;
                             owl:maxCardinality "1"^^xsd:nonNegativeInteger
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty mo:confidence ;
                             owl:cardinality "1"^^xsd:nonNegativeInteger
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty mo:observed_name ;
                             owl:maxCardinality "1"^^xsd:nonNegativeInteger
                           ] ;
           rdfs:label "Match Info"@en .


###  https://minmod.isi.edu/ontology/MaterialForm
mo:MaterialForm rdf:type owl:Class ;
              rdfs:subClassOf mo:ThingHasLabel ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty mo:commodity ;
                                owl:allValuesFrom mo:Commodity
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty mo:commodity ;
                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                owl:onClass mo:Commodity
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty mo:conversion ;
                                owl:cardinality "1"^^xsd:nonNegativeInteger
                              ] ;
              rdfs:label "Material Form"@en .


###  https://minmod.isi.edu/ontology/MaterialFormCandidate
mo:MaterialFormCandidate rdf:type owl:Class ;
                       rdfs:subClassOf mo:MatchInfo ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty mo:normalized_uri ;
                                         owl:allValuesFrom mo:MaterialForm
                                       ] ;
                       rdfs:label "Material Form Candidate"@en .


###  https://minmod.isi.edu/ontology/Measure
mo:Measure rdf:type owl:Class ;
         rdfs:subClassOf [ rdf:type owl:Restriction ;
                           owl:onProperty mo:unit ;
                           owl:maxCardinality "1"^^xsd:nonNegativeInteger
                         ] ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty mo:value ;
                           owl:maxCardinality "1"^^xsd:nonNegativeInteger
                         ] ;
         rdfs:label "Measure"@en .


###  https://minmod.isi.edu/ontology/MineralInventory
mo:MineralInventory rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty mo:commodity ;
                                    owl:allValuesFrom mo:CommodityCandidate
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty mo:commodity ;
                                    owl:cardinality "1"^^xsd:nonNegativeInteger
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty mo:contained_metal ;
                                    owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty mo:reference ;
                                    owl:cardinality "1"^^xsd:nonNegativeInteger
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty mo:cutoff_grade ;
                                    owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty mo:grade ;
                                    owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty mo:material_form ;
                                    owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty mo:ore ;
                                    owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty mo:date ;
                                    owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty mo:zone ;
                                    owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                  ] ;
                  rdfs:label "Mineral Inventory"@en .


###  https://minmod.isi.edu/ontology/MineralSite
mo:MineralSite rdf:type owl:Class ;
             rdfs:subClassOf mo:ThingHasLabel ,
                             mo:ThingMayHaveAltLabel ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty mo:modified_at ;
                               owl:cardinality "1"^^xsd:nonNegativeInteger
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty mo:location_info ;
                               owl:cardinality "1"^^xsd:nonNegativeInteger
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty mo:record_id ;
                               owl:cardinality "1"^^xsd:nonNegativeInteger
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty mo:source_id ;
                               owl:cardinality "1"^^xsd:nonNegativeInteger
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty mo:site_rank ;
                               owl:maxCardinality "1"^^xsd:nonNegativeInteger
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty mo:site_type ;
                               owl:maxCardinality "1"^^xsd:nonNegativeInteger
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty mo:reference ;
                               owl:minCardinality "1"^^xsd:nonNegativeInteger
                             ] ;
             rdfs:label "Mineral Site"@en .


###  https://minmod.isi.edu/ontology/MineralSystem
mo:MineralSystem rdf:type owl:Class ;
               rdfs:subClassOf [ rdf:type owl:Restriction ;
                                 owl:onProperty mo:source ;
                                 owl:allValuesFrom mo:MappableCriteria
                               ] ;
               rdfs:label "Mineral System"@en .


###  https://minmod.isi.edu/ontology/PageInfo
mo:PageInfo rdf:type owl:Class ;
          rdfs:subClassOf [ rdf:type owl:Restriction ;
                            owl:onProperty mo:bounding_box ;
                            owl:maxCardinality "1"^^xsd:nonNegativeInteger
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty mo:page ;
                            owl:cardinality "1"^^xsd:nonNegativeInteger
                          ] ;
          rdfs:label "Page Info"@en .


###  https://minmod.isi.edu/ontology/Reference
mo:Reference rdf:type owl:Class ;
           rdfs:subClassOf mo:ThingMayHaveComment ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty mo:document ;
                             owl:cardinality "1"^^xsd:nonNegativeInteger
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty mo:property ;
                             owl:maxCardinality "1"^^xsd:nonNegativeInteger
                           ] ;
           rdfs:label "Reference"@en .


###  https://minmod.isi.edu/ontology/ResourceReserveCategory
mo:ResourceReserveCategory rdf:type owl:Class ;
                         rdfs:subClassOf mo:ThingHasLabel ;
                         rdfs:label "Resource Reserve Category"@en .


###  https://minmod.isi.edu/ontology/ResourceReserveCategoryCandidate
mo:ResourceReserveCategoryCandidate rdf:type owl:Class ;
                                  rdfs:subClassOf mo:MatchInfo ,
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty mo:normalized_uri ;
                                                    owl:allValuesFrom mo:ResourceReserveCategory
                                                  ] ;
                                  rdfs:label "Resource Reserve Category Candidate"@en .


###  https://minmod.isi.edu/ontology/StateOrProvince
mo:StateOrProvince rdf:type owl:Class ;
                 rdfs:subClassOf mo:ThingHasLabel ;
                 rdfs:label "State or Province"@en .


###  https://minmod.isi.edu/ontology/StateOrProvinceCandidate
mo:StateOrProvinceCandidate rdf:type owl:Class ;
                          rdfs:subClassOf mo:MatchInfo ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty mo:normalized_uri ;
                                            owl:allValuesFrom mo:StateOrProvince
                                          ] ;
                          rdfs:label "State Or Province Candidate"@en .


###  https://minmod.isi.edu/ontology/ThingHasLabel
mo:ThingHasLabel rdf:type owl:Class ;
               rdfs:comment "Instance of this class must have rdfs:label"@en ;
               rdfs:label "Thing Has Label"@en .


###  https://minmod.isi.edu/ontology/ThingMayHaveAltLabel
mo:ThingMayHaveAltLabel rdf:type owl:Class ;
                      rdfs:comment "Instance of this class may have aliases defined by skos:altLabel"@en ;
                      rdfs:label "Thing May Have Alt Label"@en .


###  https://minmod.isi.edu/ontology/ThingMayHaveComment
mo:ThingMayHaveComment rdf:type owl:Class ;
                 rdfs:comment "Instance of this class may have rdfs:comment"@en ;
                 rdfs:label "Thing May Have Comment"@en .


###  https://minmod.isi.edu/ontology/Unit
mo:Unit rdf:type owl:Class ;
      rdfs:subClassOf mo:ThingHasLabel ;
      rdfs:label "Unit"@en .


###  https://minmod.isi.edu/ontology/UnitCandidate
mo:UnitCandidate rdf:type owl:Class ;
               rdfs:subClassOf mo:MatchInfo ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty mo:normalized_uri ;
                                 owl:allValuesFrom mo:Unit
                               ] ;
               rdfs:label "Unit Candidate"@en .


#################################################################
#    General axioms
#################################################################

[ rdf:type owl:AllDisjointClasses ;
  owl:members ( mo:BoundingBox
                mo:Commodity
                mo:CoordinateReferenceSystem
                mo:Country
                mo:DepositType
                mo:Document
                mo:EvidenceLayer
                mo:GeologyInfo
                mo:LocationInfo
                mo:MappableCriteria
                mo:MatchInfo
                mo:Measure
                mo:MineralInventory
                mo:MineralSite
                mo:MineralSystem
                mo:PageInfo
                mo:Reference
                mo:ResourceReserveCategory
                mo:StateOrProvince
                mo:Unit
              )
] .


[ rdf:type owl:AllDisjointClasses ;
  owl:members ( mo:CommodityCandidate
                mo:CoordinateReferenceSystemCandidate
                mo:CountryCandidate
                mo:DepositTypeCandidate
                mo:MaterialFormCandidate
                mo:ResourceReserveCategoryCandidate
                mo:StateOrProvinceCandidate
                mo:UnitCandidate
              )
] .


###  Generated by merging GeoChemistry and MinMod ontologies
###  Merge strategy: MinMod (full) takes precedence, mos.ttl unique properties added with comments
