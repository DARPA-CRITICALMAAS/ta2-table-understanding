@prefix : <https://geochemistry.isi.edu/ontology/> .
@prefix geo: <http://www.opengis.net/ont/geosparql#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix mo: <https://minmod.isi.edu/ontology/> .

@base <https://geochemistry.isi.edu/ontology/> .

<https://geochemistry.isi.edu/ontology/> rdf:type owl:Ontology ;
                                          rdfs:comment "Merged GeoChemistry and MinMod ontology"@en ;
                                          owl:versionInfo "1.0.0" ;
                                          owl:imports <https://minmod.isi.edu/ontology/> .

#################################################################
#    Datatypes
#################################################################

###  http://www.opengis.net/ont/geosparql#wktLiteral
geo:wktLiteral rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  https://geochemistry.isi.edu/ontology/has_analysis
:has_analysis rdf:type owl:ObjectProperty ;
              rdfs:domain :Sample ;
              rdfs:range :Analysis ;
              rdfs:label "has analysis"@en .

###  https://geochemistry.isi.edu/ontology/from_deposit
:from_deposit rdf:type owl:ObjectProperty ;
              rdfs:domain :Sample ;
              rdfs:range mo:MineralSite ;
              rdfs:label "from deposit"@en ;
              rdfs:comment "Links a geochemical sample to the mineral site/deposit it was collected from"@en .

###  https://geochemistry.isi.edu/ontology/isotope
:isotope rdf:type owl:ObjectProperty ;
         rdfs:domain :Analysis ;
         rdfs:range :Isotope ;
         rdfs:label "isotope"@en .


###  https://geochemistry.isi.edu/ontology/element
:element rdf:type owl:ObjectProperty ;
         rdfs:domain :Analysis ;
         rdfs:range :Element ;
         rdfs:label "element"@en .


###  https://minmod.isi.edu/ontology/bounding_box
mo:bounding_box rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf mo:page_info_objectproperty ;
              rdfs:range mo:BoundingBox ;
              rdfs:comment "Coordinates of the document where reference is found"@en ;
              rdfs:label "bounding box"@en .


###  https://minmod.isi.edu/ontology/category
mo:category rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf mo:mineral_inventory_objectproperty ;
          rdfs:range mo:ResourceReserveCategoryCandidate ;
          rdfs:label "category"@en .


###  https://minmod.isi.edu/ontology/commodity
mo:commodity rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf mo:material_form_objectproperty ,
                              mo:mineral_inventory_objectproperty ;
           rdfs:range [ rdf:type owl:Class ;
                        owl:unionOf ( mo:Commodity
                                      mo:CommodityCandidate
                                    )
                      ] ;
           rdfs:label "commodity"@en .


###  https://minmod.isi.edu/ontology/country
mo:country rdf:type owl:ObjectProperty ;
         rdfs:subPropertyOf mo:location_info_objectproperty ;
         rdfs:range mo:CountryCandidate ;
         rdfs:label "country"@en .


###  https://minmod.isi.edu/ontology/crs
mo:crs rdf:type owl:ObjectProperty ;
     rdfs:subPropertyOf mo:location_info_objectproperty ;
     rdfs:range mo:CoordinateReferenceSystemCandidate ;
     rdfs:comment "The Coordinate Reference System (CRS) of the location"@en ;
     rdfs:label "crs"@en .


###  https://minmod.isi.edu/ontology/cutoff_grade
mo:cutoff_grade rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf mo:mineral_inventory_objectproperty ;
              rdfs:range mo:Measure ;
              rdfs:label "cutoff grade"@en .


###  https://minmod.isi.edu/ontology/deposit_type
mo:deposit_type rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf mo:mineral_system_objectproperty ;
              rdfs:range mo:DepositType ;
              rdfs:label "deposit type"@en .


###  https://minmod.isi.edu/ontology/deposit_type_candidate
mo:deposit_type_candidate rdf:type owl:ObjectProperty ;
                        rdfs:subPropertyOf mo:mineral_site_objectproperty ;
                        rdfs:range mo:DepositTypeCandidate ;
                        rdfs:label "deposit type candidate"@en .


###  https://minmod.isi.edu/ontology/document
mo:document rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf mo:reference_objectproperty ;
          rdfs:range mo:Document ;
          rdfs:label "document"@en .


###  https://minmod.isi.edu/ontology/energy
mo:energy rdf:type owl:ObjectProperty ;
        rdfs:subPropertyOf mo:mineral_system_objectproperty ;
        rdfs:range mo:MappableCriteria ;
        rdfs:label "energy"@en .


###  https://minmod.isi.edu/ontology/geology_info
mo:geology_info rdf:type owl:ObjectProperty ;
              rdfs:range mo:GeologyInfo ;
              rdfs:label "geology info"@en .


###  https://minmod.isi.edu/ontology/grade
mo:grade rdf:type owl:ObjectProperty ;
       rdfs:subPropertyOf mo:mineral_inventory_objectproperty ;
       rdfs:range mo:Measure ;
       rdfs:label "grade"@en .


###  https://minmod.isi.edu/ontology/location_info
mo:location_info rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf mo:mineral_site_objectproperty ;
               rdfs:range mo:LocationInfo ;
               rdfs:label "location info"@en .


###  https://minmod.isi.edu/ontology/location_info_objectproperty
mo:location_info_objectproperty rdf:type owl:ObjectProperty ;
                              rdfs:subPropertyOf owl:topObjectProperty ;
                              rdfs:domain mo:LocationInfo ;
                              rdfs:label "location info objectproperty"@en .


###  https://minmod.isi.edu/ontology/mappable_criteria_objectproperty
mo:mappable_criteria_objectproperty rdf:type owl:ObjectProperty ;
                                  rdfs:subPropertyOf owl:topObjectProperty ;
                                  rdfs:domain mo:MappableCriteria ;
                                  rdfs:label "mappable criteria objectproperty"@en .


###  https://minmod.isi.edu/ontology/match_info_objectproperty
mo:match_info_objectproperty rdf:type owl:ObjectProperty ;
                           rdfs:subPropertyOf owl:topObjectProperty ;
                           rdfs:domain mo:MatchInfo ;
                           rdfs:label "match info objectproperty"@en .


###  https://minmod.isi.edu/ontology/material_form
mo:material_form rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf mo:mineral_inventory_objectproperty ;
               rdfs:range mo:MaterialFormCandidate .


###  https://minmod.isi.edu/ontology/material_form_objectproperty
mo:material_form_objectproperty rdf:type owl:ObjectProperty ;
                              rdfs:subPropertyOf owl:topObjectProperty .


###  https://minmod.isi.edu/ontology/measure_objectproperty
mo:measure_objectproperty rdf:type owl:ObjectProperty ;
                        rdfs:subPropertyOf owl:topObjectProperty ;
                        rdfs:domain mo:Measure ;
                        rdfs:label "measure objectproperty"@en .


###  https://minmod.isi.edu/ontology/mineral_inventory
mo:mineral_inventory rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf mo:mineral_site_objectproperty ;
                   rdfs:range mo:MineralInventory ;
                   rdfs:label "mineral inventory"@en .


###  https://minmod.isi.edu/ontology/mineral_inventory_objectproperty
mo:mineral_inventory_objectproperty rdf:type owl:ObjectProperty ;
                                  rdfs:subPropertyOf owl:topObjectProperty ;
                                  rdfs:domain mo:MineralInventory ;
                                  rdfs:label "mineral inventory objectproperty"@en .


###  https://minmod.isi.edu/ontology/mineral_site_objectproperty
mo:mineral_site_objectproperty rdf:type owl:ObjectProperty ;
                             rdfs:subPropertyOf owl:topObjectProperty ;
                             rdfs:domain mo:MineralSite ;
                             rdfs:label "mineral site objectproperty"@en .


###  https://minmod.isi.edu/ontology/mineral_system_objectproperty
mo:mineral_system_objectproperty rdf:type owl:ObjectProperty ;
                               rdfs:subPropertyOf owl:topObjectProperty ;
                               rdfs:domain mo:MineralSystem ;
                               rdfs:label "mineral system objectproperty"@en .


###  https://minmod.isi.edu/ontology/normalized_uri
mo:normalized_uri rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf mo:match_info_objectproperty ;
                rdfs:range [ rdf:type owl:Class ;
                             owl:unionOf ( mo:Commodity
                                           mo:CoordinateReferenceSystem
                                           mo:Country
                                           mo:DepositType
                                           mo:MaterialForm
                                           mo:ResourceReserveCategory
                                           mo:StateOrProvince
                                           mo:Unit
                                         )
                           ] ;
                rdfs:label "normalized uri"@en .


###  https://minmod.isi.edu/ontology/ore
mo:ore rdf:type owl:ObjectProperty ;
     rdfs:subPropertyOf mo:mineral_inventory_objectproperty ;
     rdfs:range mo:Measure ;
     rdfs:label "ore"@en .


###  https://minmod.isi.edu/ontology/outflow
mo:outflow rdf:type owl:ObjectProperty ;
         rdfs:subPropertyOf mo:mineral_system_objectproperty ;
         rdfs:range mo:MappableCriteria ;
         rdfs:label "outflow"@en .


###  https://minmod.isi.edu/ontology/page_info
mo:page_info rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf mo:reference_objectproperty ;
           rdfs:range mo:PageInfo ;
           rdfs:comment "List of pages and their respective bounding boxes where the reference is found"@en ;
           rdfs:label "page info"@en .


###  https://minmod.isi.edu/ontology/property
mo:property rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf mo:reference_objectproperty ;
           rdfs:range xsd:anyURI ;
           rdfs:comment "The property that this reference is for"@en ;
           rdfs:label "property"@en .


###  https://minmod.isi.edu/ontology/page_info_objectproperty
mo:page_info_objectproperty rdf:type owl:ObjectProperty ;
                          rdfs:subPropertyOf owl:topObjectProperty ;
                          rdfs:domain mo:PageInfo ;
                          rdfs:label "page info objectproperty"@en .


###  https://minmod.isi.edu/ontology/pathway
mo:pathway rdf:type owl:ObjectProperty ;
         rdfs:subPropertyOf mo:mineral_system_objectproperty ;
         rdfs:range mo:MappableCriteria ;
         rdfs:label "pathway"@en .


###  https://minmod.isi.edu/ontology/potential_dataset
mo:potential_dataset rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf mo:mappable_criteria_objectproperty ;
                   rdfs:range mo:EvidenceLayer ;
                   rdfs:label "potential dataset"@en .


###  https://minmod.isi.edu/ontology/preservation
mo:preservation rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf mo:mineral_system_objectproperty ;
              rdfs:range mo:MappableCriteria ;
              rdfs:label "preservation"@en .


###  https://minmod.isi.edu/ontology/reference
mo:reference rdf:type owl:ObjectProperty ;
           rdfs:domain [ rdf:type owl:Class ;
                         owl:unionOf ( mo:MineralSite
                                       mo:MineralInventory
                                     )
                       ] ;
           rdfs:range mo:Reference ;
           rdfs:label "reference"@en .


###  https://minmod.isi.edu/ontology/reference_objectproperty
mo:reference_objectproperty rdf:type owl:ObjectProperty ;
                          rdfs:subPropertyOf owl:topObjectProperty ;
                          rdfs:domain mo:Reference ;
                          rdfs:label "reference objectproperty"@en .


###  https://minmod.isi.edu/ontology/source
mo:source rdf:type rdf:Property ;
        rdfs:domain [ rdf:type owl:Class ;
                      owl:unionOf ( mo:MatchInfo
                                    mo:MineralSystem
                                  )
                    ] ;
        rdfs:range [ rdf:type owl:Class ;
                     owl:unionOf ( xsd:string
                                   mo:MappableCriteria
                                 )
                   ] ;
        rdfs:label "source"@en .


###  https://minmod.isi.edu/ontology/state_or_province
mo:state_or_province rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf mo:location_info_objectproperty ;
                   rdfs:range mo:StateOrProvinceCandidate ;
                   rdfs:label "state or province"@en .


###  https://minmod.isi.edu/ontology/supporting_references
mo:supporting_references rdf:type owl:ObjectProperty ;
                       rdfs:subPropertyOf mo:mappable_criteria_objectproperty ;
                       rdfs:range mo:Reference ;
                       rdfs:label "supporting references"@en .


###  https://minmod.isi.edu/ontology/trap
mo:trap rdf:type owl:ObjectProperty ;
      rdfs:subPropertyOf mo:mineral_system_objectproperty ;
      rdfs:range mo:MappableCriteria ;
      rdfs:label "trap"@en .


###  https://minmod.isi.edu/ontology/unit
mo:unit rdf:type owl:ObjectProperty ;
      rdfs:subPropertyOf mo:measure_objectproperty ;
      rdfs:range mo:UnitCandidate ;
      rdfs:comment "The unit in which the quantity is measured, eg, metric tonnes, percent"@en ;
      rdfs:label "unit"@en .


#################################################################
#    Data properties
#################################################################

###  https://geochemistry.isi.edu/ontology/date
:date rdf:type owl:DatatypeProperty ;
      rdfs:subPropertyOf owl:topDataProperty ;
      rdfs:domain :Sample ;
      rdfs:label "date"@en ;
      rdfs:comment "The date the sample was collected."@en .



###  https://geochemistry.isi.edu/ontology/description
:description rdf:type owl:DatatypeProperty ;
             rdfs:subPropertyOf owl:topDataProperty ;
             rdfs:domain :Sample ;
             rdfs:label "description"@en .


###  https://geochemistry.isi.edu/ontology/detection_limit
:detection_limit rdf:type owl:DatatypeProperty ;
                 rdfs:subPropertyOf owl:topDataProperty ;
                 rdfs:domain :Sample ;
                 rdfs:label "detection limit"@en .


###  https://geochemistry.isi.edu/ontology/detection_limit_unit
:detection_limit_unit rdf:type owl:DatatypeProperty ;
                      rdfs:subPropertyOf owl:topDataProperty ;
                      rdfs:domain :Sample ;
                      rdfs:label "detection limit unit"@en .


###  https://geochemistry.isi.edu/ontology/grade
:grade rdf:type owl:DatatypeProperty ;
       rdfs:subPropertyOf owl:topDataProperty ;
       rdfs:domain :Analysis ;
       rdfs:label "grade"@en .


###  https://geochemistry.isi.edu/ontology/grade_unit
:grade_unit rdf:type owl:DatatypeProperty ;
      rdfs:subPropertyOf owl:topDataProperty ;
      rdfs:domain :Analysis ;
      rdfs:label "grade unit"@en .


###  https://geochemistry.isi.edu/ontology/element_and_grade_unit
:element_and_grade_unit rdf:type owl:DatatypeProperty ;
       rdfs:domain :Analysis ;
       rdfs:label "element and grade unit"@en .


:aggregation_method rdf:type owl:DatatypeProperty ;
       rdfs:subPropertyOf owl:topDataProperty ;
       rdfs:domain :Analysis ;
       rdfs:label "aggregation method"@en ;
       rdfs:comment "The method used to aggregate results of one or multiple analyses for one or multiple samples (e.g., mean, median)."@en .


###  https://geochemistry.isi.edu/ontology/sample_id
:sample_id rdf:type owl:DatatypeProperty ;
           rdfs:domain :Sample ;
           rdfs:label "sample id"@en .


###  https://geochemistry.isi.edu/ontology/sample_name
:sample_name rdf:type owl:DatatypeProperty ;
             rdfs:subPropertyOf owl:topDataProperty ;
             rdfs:domain :Sample ;
             rdfs:label "sample name"@en ;
             rdfs:comment "Sample label or name as used or provided by the sample submitter."@en .


###  https://geochemistry.isi.edu/ontology/sample_local_id
:sample_local_id rdf:type owl:DatatypeProperty ;
                 rdfs:subPropertyOf owl:topDataProperty ;
                 rdfs:domain :Sample ;
                 rdfs:label "sample local id"@en ;
                 rdfs:comment "Unique sample identifier from local database, such as a PID or IGSN."@en .


###  https://geochemistry.isi.edu/ontology/sample_type
:sample_type rdf:type owl:DatatypeProperty ;
             rdfs:subPropertyOf owl:topDataProperty ;
             rdfs:domain :Sample ;
             rdfs:label "sample type"@en ;
             rdfs:comment "Type or form of the sample (e.g., half core, outcrop specimen, drill chips)."@en .


###  https://geochemistry.isi.edu/ontology/analytical_method
:analytical_method rdf:type owl:DatatypeProperty ;
       rdfs:subPropertyOf owl:topDataProperty ;
       rdfs:domain :Analysis ;
       rdfs:label "analytical method"@en ;
       rdfs:comment "The analytical method/technique used to obtain the analysis (e.g., ICP-MS)."@en .


###  https://geochemistry.isi.edu/ontology/analysis_id
:analysis_id rdf:type owl:DatatypeProperty ;
             rdfs:subPropertyOf owl:topDataProperty ;
             rdfs:domain :Analysis ;
             rdfs:label "analysis id"@en ;
             rdfs:comment "Point ID or analysis label as per the source."@en .


###  https://geochemistry.isi.edu/ontology/instrument_type
:instrument_type rdf:type owl:DatatypeProperty ;
                 rdfs:subPropertyOf owl:topDataProperty ;
                 rdfs:domain :Analysis ;
                 rdfs:label "instrument type"@en ;
                 rdfs:comment "Instrument type and model used for analysis."@en .


###  https://geochemistry.isi.edu/ontology/laboratory_location
:laboratory_location rdf:type owl:DatatypeProperty ;
                     rdfs:subPropertyOf owl:topDataProperty ;
                     rdfs:domain :Analysis ;
                     rdfs:label "laboratory location"@en ;
                     rdfs:comment "Laboratory location for the analysis."@en .


###  https://geochemistry.isi.edu/ontology/operating_conditions
:operating_conditions rdf:type owl:DatatypeProperty ;
                      rdfs:subPropertyOf owl:topDataProperty ;
                      rdfs:domain :Analysis ;
                      rdfs:label "operating conditions"@en ;
                      rdfs:comment "Operating conditions for the analysis."@en .


###  https://geochemistry.isi.edu/ontology/standards_used
:standards_used rdf:type owl:DatatypeProperty ;
                rdfs:subPropertyOf owl:topDataProperty ;
                rdfs:domain :Analysis ;
                rdfs:label "standards used"@en ;
                rdfs:comment "Standards used for the analysis."@en .


###  https://geochemistry.isi.edu/ontology/data_quality
:data_quality rdf:type owl:DatatypeProperty ;
              rdfs:subPropertyOf owl:topDataProperty ;
              rdfs:domain :Analysis ;
              rdfs:label "data quality"@en ;
              rdfs:comment "Summarised comments about the data quality, if known."@en .

###  https://geochemistry.isi.edu/ontology/mineral
:mineral rdf:type owl:DatatypeProperty ;
       rdfs:subPropertyOf owl:topDataProperty ;
       rdfs:domain :Sample ;
       rdfs:label "mineral"@en ;
       rdfs:comment "The mineral of the sample (e.g., Light-Yellow Sphalerite)"@en .

###  https://geochemistry.isi.edu/ontology/number_of_samples
:number_of_samples rdf:type owl:DatatypeProperty ;
       rdfs:subPropertyOf owl:topDataProperty ;
       rdfs:domain :Sample ;
       rdfs:label "number of samples"@en .

###  https://geochemistry.isi.edu/ontology/number_of_analyses
:number_of_analyses rdf:type owl:DatatypeProperty ;
       rdfs:subPropertyOf owl:topDataProperty ;
       rdfs:domain :Sample ;
       rdfs:label "number of analyses"@en .


###  https://geochemistry.isi.edu/ontology/sampling_method
:sampling_method rdf:type owl:DatatypeProperty ;
                 rdfs:subPropertyOf owl:topDataProperty ;
                 rdfs:domain :Sample ;
                 rdfs:label "sampling method"@en ;
                 rdfs:comment "The method used to collect the sample (e.g., core drilling, RC drilling, outcrop sampling)."@en .


###  https://geochemistry.isi.edu/ontology/sample_preparation
:sample_preparation rdf:type owl:DatatypeProperty ;
                    rdfs:subPropertyOf owl:topDataProperty ;
                    rdfs:domain :Sample ;
                    rdfs:label "sample preparation"@en ;
                    rdfs:comment "Description of sample preparation (e.g., crushing, milling)."@en .


###  https://geochemistry.isi.edu/ontology/material_class
:material_class rdf:type owl:DatatypeProperty ;
                rdfs:subPropertyOf owl:topDataProperty ;
                rdfs:domain :Sample ;
                rdfs:label "material class"@en ;
                rdfs:comment "Broad categorisation of the sample material type (e.g., rock, regolith, sediment)."@en .


###  https://geochemistry.isi.edu/ontology/material_class_comment
:material_class_comment rdf:type owl:DatatypeProperty ;
                        rdfs:subPropertyOf owl:topDataProperty ;
                        rdfs:domain :Sample ;
                        rdfs:label "material class comment"@en ;
                        rdfs:comment "Any additional comments about the sample material class/type."@en .


###  https://geochemistry.isi.edu/ontology/analysed_material
:analysed_material rdf:type owl:DatatypeProperty ;
                   rdfs:subPropertyOf owl:topDataProperty ;
                   rdfs:domain :Sample ;
                   rdfs:label "analysed material"@en ;
                   rdfs:comment "Type of material analysed (e.g., thin section, mount)."@en .


###  https://geochemistry.isi.edu/ontology/sample_deposit_relation
:sample_deposit_relation rdf:type owl:DatatypeProperty ;
                         rdfs:subPropertyOf owl:topDataProperty ;
                         rdfs:domain :Sample ;
                         rdfs:label "sample deposit relation"@en ;
                         rdfs:comment "Description of the sample's relation to the mineral deposit (e.g., high grade ore, low grade ore, gangue, alteration halo, host rock)."@en .


###  https://geochemistry.isi.edu/ontology/geological_province
:geological_province rdf:type owl:DatatypeProperty ;
                     rdfs:subPropertyOf owl:topDataProperty ;
                     rdfs:domain :Sample ;
                     rdfs:label "geological province"@en ;
                     rdfs:comment "Geological province - an extensive region characterised by similar geological history, structural, petrographic, or physiographic features."@en .


###  https://geochemistry.isi.edu/ontology/strat_unit_uid
:strat_unit_uid rdf:type owl:DatatypeProperty ;
                rdfs:subPropertyOf owl:topDataProperty ;
                rdfs:domain :Sample ;
                rdfs:label "stratigraphic unit uid"@en ;
                rdfs:comment "Unique ID (e.g., URL link) for the stratigraphic unit."@en .


###  https://geochemistry.isi.edu/ontology/strat_grouping
:strat_grouping rdf:type owl:DatatypeProperty ;
                rdfs:subPropertyOf owl:topDataProperty ;
                rdfs:domain :Sample ;
                rdfs:label "stratigraphic grouping"@en ;
                rdfs:comment "An informal classification used to classify suites of rocks from particular regions."@en .


###  https://geochemistry.isi.edu/ontology/earth_material_group
:earth_material_group rdf:type owl:DatatypeProperty ;
                      rdfs:subPropertyOf owl:topDataProperty ;
                      rdfs:domain :Sample ;
                      rdfs:label "earth material group"@en ;
                      rdfs:comment "Dominant lithological grouping (e.g., acid intrusive, sedimentary siliciclastic, sedimentary carbonate, mineralisation)."@en .


###  https://geochemistry.isi.edu/ontology/earth_material_qualifier
:earth_material_qualifier rdf:type owl:DatatypeProperty ;
                          rdfs:subPropertyOf owl:topDataProperty ;
                          rdfs:domain :Sample ;
                          rdfs:label "earth material qualifier"@en ;
                          rdfs:comment "A comma-separated list of qualifying term(s) before the lithology name field (e.g., graphitic, fine grained, foliated)."@en .


###  https://geochemistry.isi.edu/ontology/mode_occurrence
:mode_occurrence rdf:type owl:DatatypeProperty ;
                 rdfs:subPropertyOf owl:topDataProperty ;
                 rdfs:domain :Sample ;
                 rdfs:label "mode of occurrence"@en ;
                 rdfs:comment "The mode of occurrence of the sample (e.g., fracture fill, vein, xenolith)."@en .


###  https://geochemistry.isi.edu/ontology/metamorphic_grade
:metamorphic_grade rdf:type owl:DatatypeProperty ;
                   rdfs:subPropertyOf owl:topDataProperty ;
                   rdfs:domain :Sample ;
                   rdfs:label "metamorphic grade"@en ;
                   rdfs:comment "A term to describe the pressures and temperatures under which the rock formed."@en .


###  https://geochemistry.isi.edu/ontology/alteration
:alteration rdf:type owl:DatatypeProperty ;
            rdfs:subPropertyOf owl:topDataProperty ;
            rdfs:domain :Sample ;
            rdfs:label "alteration"@en ;
            rdfs:comment "An aggregated, comma separated, list of alteration types in the sample (e.g., argillic, silicified)."@en .


###  https://geochemistry.isi.edu/ontology/paragenetic_stage
:paragenetic_stage rdf:type owl:DatatypeProperty ;
                   rdfs:subPropertyOf owl:topDataProperty ;
                   rdfs:domain :Sample ;
                   rdfs:label "paragenetic stage"@en ;
                   rdfs:comment "Paragenetic stage of the sample under analysis."@en .


###  https://geochemistry.isi.edu/ontology/texture
:texture rdf:type owl:DatatypeProperty ;
         rdfs:subPropertyOf owl:topDataProperty ;
         rdfs:domain :Sample ;
         rdfs:label "texture"@en ;
         rdfs:comment "An aggregated, comma separated, list of mineral textures to describe the sample (e.g., foliated, vuggy)."@en .


###  https://geochemistry.isi.edu/ontology/color
:color rdf:type owl:DatatypeProperty ;
       rdfs:subPropertyOf owl:topDataProperty ;
       rdfs:domain :Sample ;
       rdfs:label "color"@en ;
       rdfs:comment "Colour of the main mineral being analysed."@en .


###  https://geochemistry.isi.edu/ontology/associated_minerals
:associated_minerals rdf:type owl:DatatypeProperty ;
                     rdfs:subPropertyOf owl:topDataProperty ;
                     rdfs:domain :Sample ;
                     rdfs:label "associated minerals"@en ;
